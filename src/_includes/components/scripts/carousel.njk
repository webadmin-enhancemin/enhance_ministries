// Carousel navigation
document.querySelectorAll('.team-carousel-wrapper, .testimonial-carousel-wrapper, .services-carousel-wrapper, .partners-carousel-wrapper, .blog-carousel-wrapper, .messages-carousel-wrapper, .podcasts-carousel-wrapper, .articles-carousel-wrapper, .golf-photo-carousel-wrapper, .board-carousel-wrapper, .trip-carousel-wrapper, .events-carousel-wrapper').forEach(wrapper => {
    const carousel = wrapper.querySelector('.team-carousel, .testimonial-carousel, .services-carousel, .partners-carousel, .blog-carousel, .messages-carousel, .podcasts-carousel, .articles-carousel, .golf-photo-carousel, .board-carousel, .trip-carousel, .events-carousel');
    const prevBtn = wrapper.querySelector('.carousel-btn-prev');
    const nextBtn = wrapper.querySelector('.carousel-btn-next');

    if (carousel && prevBtn && nextBtn) {
        const scrollAmount = 350;

        prevBtn.addEventListener('click', () => {
            carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });

        nextBtn.addEventListener('click', () => {
            carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
    }
});

// Auto-rotating golf photo carousel
document.querySelectorAll('.golf-photo-carousel-wrapper').forEach(wrapper => {
    const carousel = wrapper.querySelector('.golf-photo-carousel');
    if (!carousel) return;
    const slides = carousel.querySelectorAll('.golf-photo-slide');
    if (slides.length === 0) return;
    let currentIndex = 0;

    let autoPlay = setInterval(() => {
        currentIndex = (currentIndex + 1) % slides.length;
        slides[currentIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    }, 4000);

    carousel.addEventListener('mouseenter', () => clearInterval(autoPlay));
    carousel.addEventListener('touchstart', () => clearInterval(autoPlay), { passive: true });
});
